{
  "name": "w3-paypal-action",
  "version": "1.0.0",
  "private": true,
  "description": "PayPal payments, orders, payouts, subscriptions, invoicing, disputes, and vault for W3 workflows",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "test": "node --test test/*.test.js",
    "all": "npm run format && npm run lint && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@w3-io/action-core": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0"
  }
}
